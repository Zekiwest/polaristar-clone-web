{
  "name": "polaristar-clone-web",
  "version": "1.0.0",
  "description": "Website resource collector - extracts and reconstructs web pages for offline viewing with Cloudflare bypass support",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "resource-collector": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts"
  },
  "keywords": [
    "web-scraper",
    "resource-extractor",
    "website-clone"
  ],
  "license": "MIT",
  "dependencies": {
    "cheerio": "^1.0.0",
    "commander": "^12.0.0",
    "got-scraping": "^4.2.1",
    "playwright-core": "^1.58.2",
    "puppeteer-real-browser": "^1.4.4",
    "undici": "^6.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
